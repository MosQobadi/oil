generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Car {
  id                 Int      @id @default(autoincrement())
  brand              String
  model              String
  year               Int
  engine             String?
  description        String?
  imageUrl           String?
  suggestedProducts  Json?    @db.Json
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([brand, model, year])
}

model Oil {
  id            Int      @id @default(autoincrement())
  brand         String
  name          String
  model         String?
  price         Decimal  @db.Decimal(10, 2)
  badge         String?
  imageUrl      String?
  description   String?
  isActive      Boolean  @default(true)
  replacementId Int?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  replacement   Oil?     @relation("OilReplacement", fields: [replacementId], references: [id])
  replacedBy    Oil[]    @relation("OilReplacement")

  @@index([brand])
  @@index([isActive])
}

model OilFilter {
  id          Int      @id @default(autoincrement())
  brand       String
  name        String
  model       String?
  price       Decimal  @db.Decimal(10, 2)
  badge       String?
  imageUrl    String?
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([brand])
  @@index([isActive])
}

model AirFilter {
  id          Int      @id @default(autoincrement())
  brand       String
  name        String
  model       String?
  price       Decimal  @db.Decimal(10, 2)
  badge       String?
  imageUrl    String?
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([brand])
  @@index([isActive])
}

model CabinFilter {
  id          Int      @id @default(autoincrement())
  brand       String
  name        String
  model       String?
  price       Decimal  @db.Decimal(10, 2)
  badge       String?
  imageUrl    String?
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([brand])
  @@index([isActive])
}

model FuelFilter {
  id          Int      @id @default(autoincrement())
  brand       String
  name        String
  model       String?
  price       Decimal  @db.Decimal(10, 2)
  badge       String?
  imageUrl    String?
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([brand])
  @@index([isActive])
}

model User {
  id           Int       @id @default(autoincrement())
  email        String    @unique
  name         String?
  passwordHash String
  role         UserRole  @default(USER)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  sessions     Session[]
}

model Session {
  id        Int      @id @default(autoincrement())
  tokenHash String   @unique
  userId    Int
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

enum RecommendationType {
  SUGGESTED_OIL
  SUGGESTED_OIL_FILTER
  SUGGESTED_AIR_FILTER
  SUGGESTED_CABIN_FILTER
  SUGGESTED_FUEL_FILTER
}

enum UserRole {
  USER
  ADMIN
}
